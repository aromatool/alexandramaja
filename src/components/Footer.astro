---
const year = new Date().getFullYear();

const social = [
  { href: 'https://facebook.com', label: 'Facebook', icon: 'facebook' },
  { href: 'https://instagram.com', label: 'Instagram', icon: 'instagram' },
  { href: '/#newsletter', label: 'Newsletter', icon: 'mail' },
];

const quickLinks = [
  { href: '/biblioteca', label: 'Biblioteca' },
  { href: '/despre', label: 'Despre Alexandra' },
  { href: '/lucreaza-cu-alexandra', label: 'Lucrează cu Alexandra' },
  { href: '/recomandari', label: 'Recomandările mele' },
];
---

<footer class="site-footer" aria-label="Subsol">
  <!-- Main band: quote on the left, "let's connect" + social on the right -->
  <div class="container footer-main">
    <figure class="footer-quote">
      <blockquote>„Natura nu se grăbește, dar totul se împlinește.”</blockquote>
      <figcaption>— Lao Tzu</figcaption>
    </figure>

    <div class="footer-connect">
      <p class="footer-connect-label">Hai să fim conectați și aici:</p>
      <div class="footer-social">
        {
          social.map((s) => (
            <a
              href={s.href}
              class="social-link"
              aria-label={s.label}
              rel="me noopener"
              target={s.href.startsWith('http') ? '_blank' : undefined}
            >
              {s.icon === 'facebook' && (
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M14 9h3V6h-3c-1.9 0-3 1.4-3 3.3V11H8v3h3v7h3v-7h2.5l.5-3H14V9.6c0-.4.3-.6.7-.6Z" />
                </svg>
              )}
              {s.icon === 'instagram' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                  <rect x="3.5" y="3.5" width="17" height="17" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17" cy="7" r="1" fill="currentColor" stroke="none" />
                </svg>
              )}
              {s.icon === 'mail' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="M3 7l9 6 9-6" />
                </svg>
              )}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Fine print: quick links, medical disclaimer, copyright — one unified footer -->
  <div class="container footer-fine">
    <div class="footer-fine-top">
      <span class="brand-name script">Alexandra</span>
      <nav class="footer-links" aria-label="Legături rapide">
        {quickLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
    </div>
    <p class="footer-disclaimer">
      Conținutul de pe acest site are scop <strong>educativ și informativ</strong>.
      Nu reprezintă sfat medical și nu înlocuiește consultul unui medic sau
      farmacist. Pentru probleme de sănătate, adresează-te unui specialist.
    </p>
    <p class="footer-legal">
      © {year} Alexandra Maja · Toate drepturile rezervate
    </p>
  </div>
</footer>

<style>
  .site-footer {
    /* Point --photo at the real image; the cream veil on top keeps text
       readable, and the fallback color shows if the photo is missing. */
    --photo: url('/images/footer-lavanda.jpg');
    position: relative;
    overflow: hidden;
    background-color: #e7ddcf;
    background-image:
      linear-gradient(160deg, rgba(239, 231, 221, 0.82), rgba(231, 221, 207, 0.86)),
      var(--photo);
    background-size: cover, cover;
    background-position: center, center;
    background-repeat: no-repeat, no-repeat;
  }

  /* ---- Main band: quote + connect ---- */
  .footer-main {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    align-items: center;
    gap: 2.5rem;
    padding-block: clamp(3rem, 6vw, 4.5rem);
  }

  .footer-quote blockquote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 3.2vw, 2.15rem);
    line-height: 1.3;
    color: var(--text-main);
    max-width: 22ch;
  }

  .footer-quote figcaption {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    color: var(--text-secondary);
    letter-spacing: 0.04em;
  }

  .footer-connect {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }

  .footer-connect-label {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background-color: var(--bg-soft);
    border: 1px solid var(--border-soft);
    color: var(--accent-sage-dark);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .social-link:hover {
    background-color: var(--accent-sage);
    color: var(--button-text);
    transform: translateY(-2px);
  }

  .social-link svg {
    width: 18px;
    height: 18px;
  }

  /* ---- Fine print bar ---- */
  .footer-fine {
    border-top: 1px solid var(--border-soft);
    padding-block: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-fine-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-fine-top .brand-name {
    font-size: 1.65rem;
    color: var(--text-main);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .footer-links a:hover {
    color: var(--accent-lavender-deep);
  }

  .footer-disclaimer {
    font-size: 0.85rem;
    color: var(--text-muted);
    max-width: 75ch;
    line-height: 1.6;
  }

  .footer-legal {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (max-width: 760px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      text-align: center;
    }
    .footer-quote blockquote {
      margin-inline: auto;
    }
    .footer-connect {
      align-items: center;
      text-align: center;
    }
    .footer-fine-top {
      justify-content: center;
    }
  }
</style>
