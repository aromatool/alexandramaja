---
// Primary navigation. The Biblioteca dropdown lists the library's shelves;
// each links to /biblioteca#<slug>, which preselects that category on the
// Biblioteca index (client-side filter + deep-link).
interface NavChild {
  href: string;
  label: string;
  emoji?: string;
}
interface NavItem {
  href: string;
  label: string;
  activeMatch?: string; // path prefix that lights this item; omit = never
  children?: NavChild[];
}

const links: NavItem[] = [
  { href: '/', label: 'Acasă', activeMatch: '/' },
  { href: '/despre', label: 'Despre Alexandra', activeMatch: '/despre' },
  {
    href: '/biblioteca',
    label: 'Biblioteca',
    activeMatch: '/biblioteca',
    children: [
      { href: '/biblioteca', label: 'Toate articolele' },
      { href: '/biblioteca#plante', label: 'Plante', emoji: '🌿' },
      { href: '/biblioteca#aromaterapie', label: 'Aromaterapie', emoji: '🌸' },
      { href: '/biblioteca#ceaiuri', label: 'Ceaiuri', emoji: '🍵' },
      { href: '/biblioteca#stil-de-viata', label: 'Stil de viață', emoji: '🌞' },
      { href: '/biblioteca#familie', label: 'Familie', emoji: '💛' },
      { href: '/biblioteca#carti-conferinte', label: 'Cărți & Conferințe', emoji: '📚' },
      { href: '/biblioteca#jurnal', label: 'Jurnal', emoji: '✍️' },
    ],
  },
  { href: '/lucreaza-cu-alexandra', label: 'Lucrează cu Alexandra', activeMatch: '/lucreaza-cu-alexandra' },
  { href: '/recomandari', label: 'Recomandările mele', activeMatch: '/recomandari' },
];

const path = Astro.url.pathname;
const isActive = (item: NavItem) => {
  if (!item.activeMatch) return false;
  return item.activeMatch === '/' ? path === '/' : path.startsWith(item.activeMatch);
};
---

<header class="site-header">
  <div class="container header-inner">
    <!-- Brand -->
    <a href="/" class="brand" aria-label="Alexandra — acasă">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 40 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M20 42 V20" stroke="var(--accent-sage-dark)" stroke-width="1.3" stroke-linecap="round" />
          <path d="M20 22 c0-5 2.8-9 7-10.6 -0.4 5-2.8 9-7 10.6Z" fill="var(--accent-lavender)" fill-opacity="0.25" stroke="var(--accent-lavender)" stroke-width="1.2" />
          <path d="M20 22 c0-5 -2.8-9 -7-10.6 0.4 5 2.8 9 7 10.6Z" fill="var(--accent-lavender)" fill-opacity="0.25" stroke="var(--accent-lavender)" stroke-width="1.2" />
          <path d="M20 30 c0-4 2.4-7.2 6-8.6" stroke="var(--accent-sage)" stroke-width="1.2" stroke-linecap="round" />
          <path d="M20 30 c0-4 -2.4-7.2 -6-8.6" stroke="var(--accent-sage)" stroke-width="1.2" stroke-linecap="round" />
          <path d="M14 8 c1.6 0.4 2.8 1.6 3.4 3.2" stroke="var(--accent-lavender)" stroke-width="1.1" stroke-linecap="round" />
          <path d="M26 8 c-1.6 0.4 -2.8 1.6 -3.4 3.2" stroke="var(--accent-lavender)" stroke-width="1.1" stroke-linecap="round" />
        </svg>
      </span>
      <span class="brand-text">
        <span class="brand-name">Alexandra</span>
        <span class="brand-sub">Plante • Aromaterapie • Viață</span>
      </span>
    </a>

    <!-- Mobile toggle -->
    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <label for="nav-toggle" class="nav-burger" aria-label="Meniu">
      <span></span><span></span><span></span>
    </label>

    <!-- Primary nav -->
    <nav class="site-nav" aria-label="Navigație principală">
      <ul class="nav-list">
        {
          links.map((item) => (
            <li class:list={['nav-item', { 'has-children': item.children }]}>
              <a
                href={item.href}
                class:list={['nav-link', { active: isActive(item) }]}
                aria-current={isActive(item) ? 'page' : undefined}
              >
                {item.label}
                {item.children && (
                  <svg class="nav-caret" viewBox="0 0 10 6" aria-hidden="true">
                    <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.3" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
              </a>
              {item.children && (
                <ul class="submenu">
                  {item.children.map((child) => (
                    <li>
                      <a href={child.href}>
                        {child.emoji && <span class="submenu-emoji" aria-hidden="true">{child.emoji}</span>}
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Actions -->
    <div class="header-actions">
      <a href="/biblioteca" class="icon-btn" aria-label="Caută în bibliotecă">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="M21 21l-4.3-4.3" />
        </svg>
      </a>
      <a href="/#newsletter" class="btn btn-outline header-cta">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="cta-icon">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <path d="M3 7l9 6 9-6" />
        </svg>
        Abonează-te
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(244, 237, 230, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border-soft);
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding-block: 0.9rem;
  }

  /* Brand */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--text-main);
  }

  .brand-mark {
    width: 34px;
    height: 38px;
    flex: none;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .brand-name {
    font-family: var(--font-script);
    font-size: 1.9rem;
    letter-spacing: 0.02em;
    color: var(--text-main);
  }

  .brand-sub {
    font-family: var(--font-body);
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 0.2rem;
  }

  /* Nav */
  .site-nav {
    justify-self: center;
  }

  .nav-list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;   /* 15px */
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.4rem 0;
    white-space: nowrap;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 0;
    height: 1.5px;
    background-color: var(--accent-lavender);
    transition: width 0.25s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text-main);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-caret {
    width: 9px;
    height: 6px;
    color: var(--text-muted);
    transition: transform 0.2s ease;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .submenu {
    list-style: none;
    position: absolute;
    top: calc(100% + 0.6rem);
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    min-width: 210px;
    background-color: var(--bg-soft);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 60;
  }

  .submenu::before {
    /* hover bridge so the menu doesn't close in the gap */
    content: '';
    position: absolute;
    top: -0.6rem;
    left: 0;
    right: 0;
    height: 0.6rem;
  }

  .nav-item:hover .submenu,
  .nav-item:focus-within .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .submenu a {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 0.85rem;
    border-radius: 6px;
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-decoration: none;
    white-space: nowrap;
  }

  .submenu-emoji {
    font-size: 1rem;
    line-height: 1;
    width: 1.25em;
    text-align: center;
  }

  .submenu a:hover {
    background-color: var(--tint-sage);
    color: var(--text-main);
  }

  /* Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: end;
  }

  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    color: var(--text-secondary);
    border: 1px solid transparent;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .icon-btn:hover {
    background-color: var(--tint-sage);
    color: var(--text-main);
  }

  .icon-btn svg {
    width: 19px;
    height: 19px;
  }

  .header-cta {
    padding: 0.6rem 1.15rem;
    font-size: 0.875rem;
  }

  .cta-icon {
    width: 16px;
    height: 16px;
  }

  /* Mobile burger */
  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    cursor: pointer;
    border-radius: 10px;
    justify-self: end;
  }

  .nav-burger span {
    display: block;
    height: 2px;
    width: 24px;
    margin-inline: auto;
    background-color: var(--text-main);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  @media (max-width: 1080px) {
    .header-inner {
      grid-template-columns: auto auto;
      justify-content: space-between;
    }

    .nav-burger {
      display: flex;
      order: 3;
    }

    .header-actions {
      display: none;
    }

    .site-nav {
      /* NOTE: .site-header uses backdrop-filter, which makes it the containing
         block for this position:fixed drawer. So we can't rely on inset/bottom
         stretching to the viewport — set an explicit full-height instead. */
      position: fixed;
      top: 0;
      right: 0;
      left: auto;
      width: min(85vw, 340px);
      height: 100vh;
      height: 100dvh;
      justify-self: stretch;
      background-color: var(--bg-page);
      border-left: 1px solid var(--border-soft);
      box-shadow: var(--shadow-soft);
      padding: 5.5rem 1.75rem 2rem;
      overflow-y: auto;
      transform: translateX(100%);
      transition: transform 0.3s ease;
    }

    .nav-toggle:checked ~ .site-nav {
      transform: translateX(0);
    }

    .nav-list {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
      width: 100%;
    }

    .nav-item {
      width: 100%;
    }

    .nav-link {
      font-size: 1.1rem;
      padding: 0.6rem 0;
    }

    .nav-caret {
      display: none;
    }

    /* Show submenus inline on mobile */
    .submenu {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      box-shadow: none;
      border: none;
      background: transparent;
      padding: 0 0 0.5rem 0.75rem;
      min-width: 0;
    }

    .submenu a {
      padding: 0.4rem 0.5rem;
      color: var(--text-muted);
    }

    .nav-toggle:checked ~ .nav-burger span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(2) {
      opacity: 0;
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
