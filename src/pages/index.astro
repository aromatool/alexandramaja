---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';

const articles = (await getCollection('biblioteca', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const benefits = [
  { icon: 'sprout', title: 'Experiență reală', text: 'Testez înainte să recomand' },
  { icon: 'heart', title: 'Abordare holistică', text: 'Privesc omul în întregime' },
  { icon: 'flower', title: 'Încredere și sinceritate', text: 'Fără promisiuni, doar adevăr' },
  { icon: 'home', title: 'Inspirație pentru fiecare zi', text: 'Idei simple, aplicabile' },
];
---

<BaseLayout>
  <!-- ================= HERO ================= -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="hero-rule" aria-hidden="true"></span>
        <h1 class="hero-title">
          Natură. Echilibru.<br />
          <span class="script hero-accent">Viață cu sens.</span>
        </h1>
        <p class="hero-sub">
          Inspirație din plante, aromaterapie și alegeri conștiente pentru o
          viață mai simplă, mai sănătoasă și mai frumoasă.
        </p>
        <a href="/biblioteca" class="btn btn-primary hero-btn">
          Intră în bibliotecă
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 20A7 7 0 0 1 4 13c0-6 8-9 15-9 0 7-3 16-9 16Z" />
            <path d="M7 17c4-1 7-4 8-8" />
          </svg>
        </a>
      </div>

      <figure class="hero-quote">
        <blockquote>
          Când ne întoarcem la simplitate, ne întoarcem la noi înșine.
        </blockquote>
        <span class="hero-quote-heart" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20s-7-4.5-9.5-9C1 8 2.5 4.5 6 4.5c2 0 3.3 1.2 4 2.3.7-1.1 2-2.3 4-2.3 3.5 0 5 3.5 3.5 6.5C19 15.5 12 20 12 20Z" />
          </svg>
        </span>
      </figure>
    </div>
  </section>

  <!-- ================= BENEFITS ================= -->
  <section class="benefits">
    <div class="container benefits-inner">
      {
        benefits.map((b) => (
          <div class="benefit">
            <span class="benefit-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                {b.icon === 'sprout' && (
                  <>
                    <path d="M12 21V11" />
                    <path d="M12 13c0-3.5 2.2-6.4 5.5-7.4-.3 3.6-2.2 6.5-5.5 7.4Z" />
                    <path d="M12 15c0-3-2-5.6-5-6.5.3 3 2 5.6 5 6.5Z" />
                  </>
                )}
                {b.icon === 'heart' && (
                  <path d="M12 20s-7-4.5-9.5-9C1 8 2.5 4.5 6 4.5c2 0 3.3 1.2 4 2.3.7-1.1 2-2.3 4-2.3 3.5 0 5 3.5 3.5 6.5C19 15.5 12 20 12 20Z" />
                )}
                {b.icon === 'flower' && (
                  <>
                    <circle cx="12" cy="9" r="2.2" />
                    <path d="M12 6.8c-.6-2 .3-3.8 1.6-4.3.6 1.9-.1 3.6-1.6 4.3Z" />
                    <path d="M12 6.8c.6-2-.3-3.8-1.6-4.3-.6 1.9.1 3.6 1.6 4.3Z" />
                    <path d="M13.9 10c1.9-.8 3.8-.2 4.5 1-1.8.9-3.6.4-4.5-1Z" />
                    <path d="M10.1 10c-1.9-.8-3.8-.2-4.5 1 1.8.9 3.6.4 4.5-1Z" />
                    <path d="M12 11.2V21" />
                  </>
                )}
                {b.icon === 'home' && (
                  <>
                    <path d="M4 11l8-6 8 6" />
                    <path d="M6 10v9h12v-9" />
                    <path d="M10 19v-5h4v5" />
                  </>
                )}
              </svg>
            </span>
            <div class="benefit-text">
              <h3>{b.title}</h3>
              <p>{b.text}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ================= ABOUT · ARTICLES · NEWSLETTER ================= -->
  <section class="section home-band">
    <div class="container home-grid">
      <!-- About -->
      <div class="home-about">
        <span class="script home-script">Bun venit!</span>
        <h2>Despre mine</h2>
        <p>
          Sunt pasionată de plante, de aromaterapie și de modul în care natura
          ne poate susține fiecare pas. Călătoresc, învăț, experimentez și
          împărtășesc aici tot ce descopăr și trăiesc.
        </p>
        <a href="/despre" class="text-link">Cine e Alexandra →</a>
        <div class="about-photo" role="img" aria-label="Lavandă și pălărie de pai"></div>
      </div>

      <!-- Latest articles -->
      <div class="home-articles">
        <span class="script home-script">Din bibliotecă</span>
        {
          articles.length > 0 ? (
            <div class="home-articles-grid">
              {articles.map((article) => (
                <ArticleCard article={article} />
              ))}
            </div>
          ) : (
            <p class="home-empty">Primele articole apar în curând. 🌿</p>
          )
        }
        <a href="/biblioteca" class="text-link home-articles-all">Toată biblioteca →</a>
      </div>

      <!-- Newsletter -->
      <div class="home-newsletter">
        <NewsletterSignup variant="card" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===================== HERO ===================== */
  /* Point --hero-img at the real photo once it exists; until then the warm
     fallback gradient below shows through gracefully (a 404 url paints nothing). */
  .hero {
    --hero-img: url('/images/hero.jpg');
    position: relative;
    isolation: isolate;
    overflow: hidden;
    /* fallback so the right side is never blank before the photo lands */
    background: linear-gradient(115deg, #efe7dd 0%, #e7ddcf 52%, #d8c9b3 100%);
  }

  /* photo layer + cream fade on the left, baked into one layer so the text
     stays readable over the image */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(
        90deg,
        var(--bg-page) 0%,
        rgba(244, 237, 230, 0.88) 16%,
        rgba(244, 237, 230, 0.45) 36%,
        rgba(244, 237, 230, 0) 60%
      ),
      var(--hero-img);
    background-size: cover, cover;
    background-position: center, center right;
    background-repeat: no-repeat, no-repeat;
  }

  .hero-inner {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(480px, 60vh, 660px);
    padding-block: clamp(2.5rem, 5vw, 4.5rem);
  }

  .hero-text {
    max-width: 34rem;
    padding-block: 1rem;
  }

  .hero-rule {
    display: block;
    width: 54px;
    height: 2px;
    background-color: var(--accent-sage);
    margin-bottom: 1.75rem;
  }

  .hero-title {
    font-size: clamp(2.6rem, 5.2vw, 4rem);
    line-height: 1.04;
  }

  .hero-accent {
    display: inline-block;
    font-size: clamp(2.6rem, 5vw, 3.6rem);
    margin-top: 0.35rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 42ch;
    margin-top: 1.75rem;
  }

  .hero-btn {
    margin-top: 2rem;
  }

  .hero-btn svg {
    width: 17px;
    height: 17px;
  }

  /* Quote card resting flush against the hero's bottom edge, as in the mockup */
  .hero-quote {
    position: absolute;
    left: clamp(1.25rem, 40%, 46rem);
    bottom: 0;
    z-index: 2;
    width: min(258px, 42vw);
    background-color: var(--bg-soft);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius) var(--radius) 0 0;
    box-shadow: 0 -6px 24px rgba(74, 63, 53, 0.1);
    padding: 1.4rem 1.6rem 1.5rem;
    text-align: center;
  }

  .hero-quote blockquote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.4;
    color: var(--text-main);
  }

  .hero-quote-heart {
    display: inline-flex;
    margin-top: 0.85rem;
    color: var(--accent-lavender);
  }

  .hero-quote-heart svg {
    width: 20px;
    height: 20px;
  }

  /* ===================== BENEFITS ===================== */
  .benefits {
    border-block: 1px solid var(--border-soft);
    background-color: var(--bg-soft);
  }

  .benefits-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem 2rem;
    padding-block: clamp(2rem, 4vw, 3rem);
  }

  .benefit {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .benefit-icon {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: var(--tint-sage);
    color: var(--accent-sage-dark);
  }

  .benefit-icon svg {
    width: 24px;
    height: 24px;
  }

  .benefit-text h3 {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-main);
    letter-spacing: 0;
    line-height: 1.3;
  }

  .benefit-text p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-top: 0.15rem;
  }

  /* ===================== HOME BAND ===================== */
  .home-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.35fr 0.9fr;
    gap: clamp(2rem, 4vw, 3.25rem);
    align-items: start;
  }

  .home-script {
    font-size: 1.7rem;
    display: block;
    margin-bottom: 0.25rem;
  }

  .home-about h2 {
    margin-bottom: 0.9rem;
  }

  .home-about p {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .text-link {
    display: inline-block;
    margin-top: 1.1rem;
    font-weight: 500;
    color: var(--accent-sage-dark);
    text-decoration: none;
  }

  .text-link:hover {
    color: var(--accent-lavender-deep);
  }

  .about-photo {
    --photo: url('/images/despre-acasa.jpg');
    margin-top: 1.75rem;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    border: 1px solid var(--border-soft);
    background-image:
      var(--photo),
      radial-gradient(120% 120% at 30% 25%, var(--tint-sage) 0%, transparent 60%),
      linear-gradient(150deg, #efe7dd, #e8e1d2);
    background-size: cover, auto, auto;
    background-position: center;
    background-repeat: no-repeat;
  }

  .home-articles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-top: 0.75rem;
  }

  .home-articles-all {
    margin-top: 1.5rem;
  }

  .home-empty {
    color: var(--text-secondary);
    margin-top: 0.75rem;
  }

  .home-newsletter {
    position: sticky;
    top: 6rem;
  }

  /* ===================== RESPONSIVE ===================== */
  @media (max-width: 1080px) {
    .home-grid {
      grid-template-columns: 1fr 1fr;
    }
    .home-newsletter {
      grid-column: 1 / -1;
      position: static;
    }
  }

  @media (max-width: 900px) {
    /* text now sits over the full photo — swap the side fade for an overall
       cream veil so the copy stays readable */
    .hero::before {
      background-image:
        linear-gradient(
          180deg,
          rgba(244, 237, 230, 0.92) 0%,
          rgba(244, 237, 230, 0.55) 42%,
          rgba(244, 237, 230, 0.72) 100%
        ),
        var(--hero-img);
      background-position: center, center;
    }
    .hero-inner {
      flex-direction: column;
      align-items: stretch;
      min-height: auto;
      padding-block: clamp(2.5rem, 8vw, 4rem);
    }
    .hero-text {
      max-width: none;
    }
    .hero-quote {
      position: static;
      width: auto;
      margin-top: 2.25rem;
      border-radius: var(--radius);
      box-shadow: var(--shadow-soft);
    }
    .benefits-inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 680px) {
    .home-grid {
      grid-template-columns: 1fr;
    }
    .home-articles-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .benefits-inner {
      grid-template-columns: 1fr;
    }
    .home-articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
