---
import BaseLayout from '../layouts/BaseLayout.astro';
import BotanicalDivider from '../components/BotanicalDivider.astro';

// O SINGURĂ ofertă la MVP. Pagina nu e un meniu de servicii — e o invitație
// la o singură întâlnire, gândită în jurul transformării (de la „copleșit și
// pe bucăți” → la „limpede, așezat și însoțit”). Fără coș, fără urgență,
// fără limbaj de coach, fără promisiuni medicale.

// Numele ofertei. Ales ca să numească valoarea (claritatea), nu „relaxarea”.
// De validat final în vocea Alexandrei.
const offerName = 'Punem lucrurile în ordine';

// Endpoint-ul unde ajung cererile de programare (Formspree).
// Îl iei de la formspree.io și îl pui aici, ex: 'https://formspree.io/f/xxxxxxx'.
// Cât timp e gol, formularul rămâne în mod demo (afișează doar un mesaj).
const BOOKING_ENDPOINT = 'https://formspree.io/f/maqrdylo';

// Cum decurge întâlnirea — pași, nu „features”.
const flow = [
  {
    step: '01',
    title: 'Începem cu o discuție',
    text: 'Nu cu o listă de simptome. Îmi povestești cum îți e — cum dormi, cum mănânci, ce te apasă, ce te bucură. Eu ascult și pun întrebări. De aici încep să se lege lucrurile.',
  },
  {
    step: '02',
    title: 'Facem o scanare ZYTO',
    text: 'O citire bioenergetică, blândă și neinvazivă — pui mâna pe un senzor, atât. Nu e un test medical și nu pune diagnostice. E o hartă în plus, care ne ajută să vedem unde să ne uităm mai atent.',
  },
  {
    step: '03',
    title: 'Așezăm totul la un loc',
    text: 'Îți explic ce văd, pe înțelesul tău, fără termeni care sperie. Legăm ce mi-ai povestit cu ce arată scanarea — ca să vezi întregul, nu bucăți.',
  },
  {
    step: '04',
    title: 'Pleci cu o direcție',
    text: 'Câțiva pași concreți, potriviți pentru tine: plante, uleiuri esențiale, obiceiuri mici, lucruri de schimbat încet. Nimic copleșitor. De unde să începi, și încotro.',
  },
];

// Ce iei cu tine — rezultatul emoțional, nu „ce primești”.
const takeaways = [
  'Sentimentul că, în sfârșit, cineva s-a uitat la tine întreg.',
  'Claritate: de unde să începi și ce contează cu adevărat acum.',
  'Un plan simplu, al tău — nu o listă de reguli generale.',
  'Liniștea de a nu mai bâjbâi singură prin informații.',
];

// Pentru cine e / pentru cine nu — auto-selecție onestă.
const forYou = [
  'Simți că faci multe „cum trebuie”, dar tot nu se așază nimic.',
  'Vrei să înțelegi întregul, nu doar să stingi un simptom.',
  'Cauți pe cineva care ascultă, nu care îți vinde.',
  'Ești dispusă să mergi încet și cu răbdare.',
];

const notForYou = [
  'Cauți un diagnostic sau un tratament medical.',
  'Vrei o soluție rapidă, „o pastilă” care rezolvă tot.',
  'Aștepți promisiuni de vindecare — eu nu le fac.',
];

// FAQ — răspunde la fricile reale, cu sinceritate.
const faqs = [
  {
    q: 'Înlocuiește asta medicul?',
    a: 'Nu, în niciun caz. Nu sunt medic, nu pun diagnostice și nu recomand să întrerupi un tratament. Lucrez lângă medicină, nu în locul ei — pe partea de stil de viață, plante și obiceiuri.',
  },
  {
    q: 'Ce este, de fapt, scanarea ZYTO?',
    a: 'O citire bioenergetică. Pui mâna pe un senzor și softul măsoară niște răspunsuri ale corpului. E o unealtă de orientare, educativă — nu un test medical și nu un diagnostic. O folosesc ca să văd unde merită să ne uităm mai atent.',
  },
  {
    q: 'Îmi promiți că mă fac bine?',
    a: 'Nu promit rezultate. Ar fi necinstit. Ce pot să-ți promit e că mă uit la tine cu atenție, îți spun sincer ce cred și îți dau o direcție clară de la care să pornești.',
  },
  {
    q: 'Cât durează și cum ne întâlnim?',
    a: 'Ne rezervăm timp fără grabă — în jur de 90 de minute. De obicei ne vedem față în față, ca să putem face și scanarea ZYTO. Dacă îți e mai la îndemână, putem discuta și online — doar că atunci scanarea nu e posibilă; rămâne discuția holistică și recomandările. După ce trimiți cererea, îți scriu personal ca să stabilim ziua.',
  },
];

// Întrebările de reflecție din formularul de cerere (fluxul C).
// Nu întreb „ce serviciu vrei” — întreb ca să înțeleg omul.
---

<BaseLayout
  title={offerName}
  description="O întâlnire față în față, fără grabă — o discuție holistică, o scanare ZYTO și o direcție clară, potrivită pentru tine. Fără diagnostice, fără promisiuni. Doar o privire întreagă asupra ta."
>
  <!-- ===================== 1. RECUNOAȘTEREA (HERO) ===================== -->
  <section class="ragaz-hero">
    <div class="container mx-auto ragaz-hero-grid">
      <div class="ragaz-hero-text">
        <span class="eyebrow">Lucrează cu Alexandra</span>
        <h1 class="ragaz-hero-title">{offerName}</h1>
        <p class="ragaz-hero-hook">
          Dacă ai adunat prea multe informații despre sănătate și nu mai știi de
          unde să începi — hai să le așezăm, împreună.
        </p>
        <div class="ragaz-hero-body">
          <p>
            Faci multe „cum trebuie" — mănânci mai atent, iei ce ți se recomandă,
            citești, încerci — și totuși ceva nu se așază. Ești obosită într-un fel
            pe care somnul nu-l repară. Ai informație multă, dar nicio direcție.
          </p>
          <p>
            Nu ai nevoie de încă un sfat aruncat în trecere. Ai nevoie de cineva
            care să se așeze cu tine, să asculte întregul — nu doar simptomul — și
            să te ajute să vezi limpede de unde să începi.
          </p>
          <p class="ragaz-hero-close">Pleci cu o direcție, nu cu o listă.</p>
        </div>
        <a href="#programare" class="btn btn-primary ragaz-hero-cta">Hai să ne întâlnim</a>
      </div>
      <figure class="ragaz-hero-figure">
        <img
          src="/images/lucreaza-hero.jpg"
          alt="Alexandra într-un câmp de lavandă, ținând în mâini un buchet proaspăt cules"
          width="1536"
          height="2048"
          loading="eager"
          fetchpriority="high"
        />
      </figure>
    </div>
  </section>

  <BotanicalDivider />

  <!-- ===================== 2. FELUL ÎN CARE GÂNDESC ===================== -->
  <section class="section surface-cream">
    <div class="container-narrow mx-auto philosophy">
      <span class="eyebrow">Felul în care gândesc</span>
      <div class="philosophy-block">
        <h2 class="philosophy-h">Cred că trupul nu se citește pe bucăți.</h2>
        <p>
          De prea multe ori suntem tratați ca o listă de probleme separate:
          aici digestia, dincolo somnul, mai încolo energia. Eu nu lucrez așa.
          Când stăm de vorbă, mă uit la om întreg — la felul în care trăiești,
          dormi, respiri, la ce te apasă și la ce te hrănește. De acolo încep să
          se lege lucrurile.
        </p>
      </div>
      <div class="philosophy-block">
        <h2 class="philosophy-h">Nu-ți promit rezultate și nu-ți dau diagnostice.</h2>
        <p>
          Nu sunt medic și nu înlocuiesc medicul. Ce fac eu e altceva: te ajut
          să te înțelegi mai bine și să-ți construiești un ritm de viață care
          are sens <em>pentru tine</em> — cu plante, cu uleiuri esențiale, cu
          obiceiuri mici, cu răbdare. Restul vine în timp, firesc.
        </p>
        <p>
          Iar dacă, după ce stăm de vorbă, simt că nu sunt eu persoana potrivită
          pentru situația ta, îți spun sincer și te îndrum mai departe. Prefer
          asta, decât să-ți vând ceva de care n-ai nevoie.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== 3. CUM DECURGE ===================== -->
  <section class="section">
    <div class="container-narrow mx-auto">
      <div class="flow-head text-center">
        <span class="eyebrow">Cum decurge întâlnirea</span>
        <h2>Fără grabă, pas cu pas</h2>
      </div>
      <ol class="flow-list">
        {
          flow.map((f) => (
            <li class="flow-item">
              <span class="flow-step" aria-hidden="true">{f.step}</span>
              <div class="flow-body">
                <h3 class="flow-title">{f.title}</h3>
                <p class="flow-text">{f.text}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ===================== 4. CE IEI CU TINE ===================== -->
  <section class="section surface-lavender">
    <div class="container-narrow mx-auto">
      <div class="takeaways-head text-center">
        <span class="eyebrow">Ce iei cu tine</span>
        <h2>Limpezime — și un plan care e al tău</h2>
      </div>
      <ul class="takeaways-list">
        {
          takeaways.map((t) => (
            <li class="takeaway">
              <span class="takeaway-mark" aria-hidden="true">🌿</span>
              <span>{t}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ===================== 5. PENTRU CINE E / NU E ===================== -->
  <section class="section">
    <div class="container-narrow mx-auto">
      <div class="fit-grid">
        <div class="fit-col">
          <span class="eyebrow">Ți se potrivește dacă</span>
          <ul class="fit-list is-yes">
            {forYou.map((item) => (
              <li><span class="fit-mark" aria-hidden="true">✓</span>{item}</li>
            ))}
          </ul>
        </div>
        <div class="fit-col">
          <span class="eyebrow">Poate nu e pentru tine dacă</span>
          <ul class="fit-list is-no">
            {notForYou.map((item) => (
              <li><span class="fit-mark" aria-hidden="true">—</span>{item}</li>
            ))}
          </ul>
        </div>
      </div>
      <p class="fit-note text-center">
        Prefer să fim sincere de la început. Dacă ceva din stânga îți sună a
        ușurare, probabil suntem pe aceeași lungime de undă.
      </p>
    </div>
  </section>

  <!-- ===================== 6. ÎNTREBĂRI FRECVENTE ===================== -->
  <section class="section surface-cream">
    <div class="container-narrow mx-auto">
      <div class="faq-head text-center">
        <span class="eyebrow">Întrebări frecvente</span>
        <h2>Lucrurile pe care e firesc să le întrebi</h2>
      </div>
      <div class="faq-list">
        {
          faqs.map((f) => (
            <details class="faq-item">
              <summary class="faq-q">{f.q}</summary>
              <p class="faq-a">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== 7. PREȚUL ===================== -->
  <section class="section">
    <div class="container-narrow mx-auto price">
      <span class="eyebrow">Cât costă</span>
      <div class="price-card">
        <p class="price-amount">
          {/* TODO: preț real, de confirmat cu Alexandra. Placeholder. */}
          350&nbsp;lei
        </p>
        <p class="price-what">
          O întâlnire față în față, fără grabă (~90 de minute): discuția
          holistică, scanarea ZYTO, interpretarea ei și direcția personală cu
          care pleci.
        </p>
        <p class="price-note">
          Prefer să fie clar de la început. Fără costuri ascunse, fără „pachete"
          și fără să te împing spre alte servicii după.
        </p>
      </div>
    </div>
  </section>

  <BotanicalDivider />

  <!-- ===================== 8. INVITAȚIA / PROGRAMARE (flux C) ===================== -->
  <section id="programare" class="section surface-sage">
    <div class="container-narrow mx-auto booking">
      <div class="booking-head text-center">
        <span class="eyebrow">Programare</span>
        <h2>Dacă simți că are sens, hai să ne întâlnim</h2>
        <p class="lead mx-auto">
          Nu e un buton de „cumpără acum". E începutul unei discuții — fără
          presiune, și te poți răzgândi oricând.
        </p>
      </div>

      <ol class="booking-steps">
        <li><span class="booking-step-n" aria-hidden="true">1</span>Îmi lași câteva rânduri despre tine, în formularul de mai jos.</li>
        <li><span class="booking-step-n" aria-hidden="true">2</span>Îți răspund personal, de obicei în câteva zile.</li>
        <li><span class="booking-step-n" aria-hidden="true">3</span>Dacă simțim amândouă că e potrivit, stabilim ziua.</li>
        <li><span class="booking-step-n" aria-hidden="true">4</span>Rezervi locul și ne vedem, fără grabă.</li>
      </ol>

      {/*
        Fluxul C: cererea ajunge la Alexandra pe email (prin Formspree),
        ea confirmă personal, apoi omul plătește ca să rezerve. Plata NU e
        automată pe site — deliberat. Endpoint-ul e în BOOKING_ENDPOINT (sus).
      */}
      <form
        class="booking-form"
        data-booking
        action={BOOKING_ENDPOINT || undefined}
        method="POST"
      >
        <input type="hidden" name="_subject" value="Cerere nouă de programare (site)" />
        <div class="field">
          <label for="b-name">Numele tău</label>
          <input id="b-name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="b-email">Adresa de email</label>
          <input id="b-email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="b-phone">Numărul de telefon</label>
          <input id="b-phone" name="phone" type="tel" required autocomplete="tel" />
        </div>
        <div class="field">
          <label for="b-why">Ce te-a făcut să te gândești la întâlnirea asta acum?</label>
          <textarea id="b-why" name="why" rows="3"></textarea>
        </div>
        <div class="field">
          <label for="b-hope">Ce ai vrea să înțelegi mai bine despre tine?</label>
          <textarea id="b-hope" name="hope" rows="3"></textarea>
        </div>
        <button type="submit" class="btn btn-warm">Trimite cererea</button>
        <p class="booking-fineprint">
          Îți răspund personal, de obicei în câteva zile. Nu ajungi pe nicio
          listă și nu primești mesaje automate.
        </p>
      </form>
      <p class="booking-note" data-booking-note hidden>
        Mulțumesc — am primit rândurile tale. Îți scriu personal în câteva zile,
        ca să vedem împreună dacă e potrivit. 🌿
      </p>
      <p class="booking-error" data-booking-error hidden>
        Ceva n-a mers la trimitere. Mai încearcă o dată sau scrie-mi direct pe
        email. Îmi pare rău pentru bătaia de cap.
      </p>
    </div>
  </section>

  <!-- ===================== 9. NOTA PERSONALĂ ===================== -->
  <section class="section personal">
    <div class="container-reading mx-auto personal-inner">
      <p class="personal-text">
        Nu fac asta ca să adun clienți. O fac pentru că îmi place să văd omul
        din fața mea cum începe să respire mai ușor când, în sfârșit, cineva
        se așază lângă el și ascultă. Dacă simți că e momentul, te aștept.
      </p>
      <p class="personal-sign script">Alexandra</p>
    </div>
  </section>

  <!-- ===================== 10. OFF-RAMP NEWSLETTER ===================== -->
  <section class="section surface-cream offramp">
    <div class="container-narrow mx-auto text-center">
      <span class="eyebrow">Dacă nu e încă momentul</span>
      <h2 class="offramp-h">Nu-i nicio grabă</h2>
      <p class="lead mx-auto offramp-text">
        Poate vrei doar să mă cunoști mai întâi. Din când în când îți scriu
        personal — un gând, un mic ritual, lucruri pe care le învăț. E gratuit
        și poți renunța oricând.
      </p>
      <form class="offramp-form" data-newsletter>
        <label class="visually-hidden" for="or-email">Adresa ta de email</label>
        <input
          id="or-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="adresa ta de email"
        />
        <button type="submit" class="btn btn-outline">Mă abonez — gratuit</button>
        <p class="offramp-note" data-newsletter-note hidden>
          Gata — te-ai abonat. Ne auzim curând. 🌿
        </p>
        <p class="offramp-error" data-newsletter-error hidden>
          Ceva n-a mers. Mai încearcă o dată în câteva momente.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===================== 1. HERO / RECUNOAȘTERE ===================== */
  .ragaz-hero {
    padding-block: clamp(2.5rem, 6vw, 5rem) clamp(1.5rem, 4vw, 2.5rem);
  }

  .ragaz-hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .ragaz-hero-text {
    max-width: 46ch;
  }

  .ragaz-hero-title {
    margin-block: 0.25rem 1.25rem;
  }

  .ragaz-hero-hook {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.8vw, 1.7rem);
    line-height: 1.35;
    color: var(--accent-lavender-deep);
    margin: 0 0 1.75rem;
  }

  .ragaz-hero-body {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .ragaz-hero-close {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    color: var(--accent-lavender-deep);
    margin-top: 0.5rem;
  }

  .ragaz-hero-cta {
    margin-top: 2rem;
  }

  .ragaz-hero-figure {
    margin: 0;
  }

  .ragaz-hero-figure img {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 620px;
    object-fit: cover;
    border-radius: 1.25rem;
    box-shadow: 0 18px 45px -20px rgba(49, 45, 29, 0.45);
  }

  @media (max-width: 820px) {
    .ragaz-hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .ragaz-hero-text {
      max-width: 52ch;
      margin-inline: auto;
      order: 2;
    }

    .ragaz-hero-figure {
      order: 1;
    }

    .ragaz-hero-figure img {
      max-height: 460px;
      max-width: 400px;
      margin-inline: auto;
    }
  }

  /* ===================== 2. FILOZOFIE ===================== */
  .philosophy-block + .philosophy-block {
    margin-top: clamp(1.75rem, 4vw, 2.5rem);
  }

  .philosophy-h {
    font-size: clamp(1.4rem, 2.8vw, 1.75rem);
    margin-bottom: 0.75rem;
  }

  .philosophy p {
    color: var(--text-secondary);
  }

  /* ===================== 3. CUM DECURGE ===================== */
  .flow-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .flow-head h2 {
    margin-top: 0.5rem;
  }

  .flow-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .flow-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.5rem;
    padding-block: clamp(1.5rem, 3vw, 2rem);
    border-top: 1px solid var(--border-soft);
  }
  .flow-item:first-child {
    border-top: none;
  }

  .flow-step {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--accent-terracotta);
    line-height: 1;
  }

  .flow-title {
    font-size: 1.3rem;
    margin-bottom: 0.4rem;
  }

  .flow-text {
    color: var(--text-secondary);
  }

  /* ===================== 4. CE IEI CU TINE ===================== */
  .takeaways-head {
    margin-bottom: clamp(1.75rem, 4vw, 2.5rem);
  }
  .takeaways-head h2 {
    margin-top: 0.5rem;
  }

  .takeaways-list {
    list-style: none;
    display: grid;
    gap: 1.1rem;
    max-width: 620px;
    margin-inline: auto;
  }

  .takeaway {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    font-size: 1.1rem;
    color: var(--text-main);
  }

  .takeaway-mark {
    flex: none;
    line-height: 1.6;
  }

  /* ===================== 5. PENTRU CINE ===================== */
  .fit-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 3.5rem);
  }

  .fit-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    margin-top: 0.5rem;
  }

  .fit-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    color: var(--text-secondary);
  }

  .fit-mark {
    flex: none;
    font-weight: 700;
  }
  .is-yes .fit-mark {
    color: var(--accent-sage-dark);
  }
  .is-no .fit-mark {
    color: var(--accent-terracotta);
  }

  .fit-note {
    margin-top: 2.5rem;
    font-style: italic;
    color: var(--text-muted);
    max-width: 52ch;
    margin-inline: auto;
  }

  /* ===================== 6. FAQ ===================== */
  .faq-head {
    margin-bottom: clamp(1.75rem, 4vw, 2.5rem);
  }
  .faq-head h2 {
    margin-top: 0.5rem;
  }

  .faq-list {
    max-width: 680px;
    margin-inline: auto;
  }

  .faq-item {
    border-top: 1px solid var(--border-soft);
    padding-block: 1.1rem;
  }
  .faq-item:last-child {
    border-bottom: 1px solid var(--border-soft);
  }

  .faq-q {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--text-main);
    cursor: pointer;
    list-style: none;
    display: flex;
