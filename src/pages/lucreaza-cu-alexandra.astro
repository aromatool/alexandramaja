---
import BaseLayout from '../layouts/BaseLayout.astro';
import BotanicalDivider from '../components/BotanicalDivider.astro';

// The offerings, in the order Alexandra wants people to meet them: the free,
// low-pressure door first; the paid/personal things next; the "someday"
// things clearly marked; and the Young Living mention kept deliberately quiet.
const offers = [
  {
    emoji: '🤍',
    kicker: 'Când ai o întrebare concretă',
    title: 'Consultații',
    text: 'Dacă ai o situație anume și vrei o privire de ansamblu, putem vorbi — calm, fără grabă. Îți spun sincer ce cred și ce aș încerca eu.',
    fineprint:
      'Ca să fim clari: nu pun diagnostice, nu înlocuiesc medicul sau farmacistul și nu promit vindecări. Lucrez lângă medicină, nu în locul ei.',
    status: 'available',
    action: { href: '#contact', label: 'Hai să vorbim' },
  },
  {
    emoji: '🌿',
    kicker: 'Făcute cu mâna mea',
    title: 'Produsele mele',
    text: 'Ceaiuri, blenduri, creme și lucruri handmade — pregătite în cantități mici, cu ingrediente în care am încredere. Apar aici pe măsură ce sunt gata.',
    tags: ['Ceaiuri', 'Blenduri', 'Creme', 'Handmade'],
    status: 'soon',
  },
  {
    emoji: '🌾',
    kicker: 'Împreună, față în față',
    title: 'Workshop-uri',
    text: 'Întâlniri mici, pe teme care revin des — plante, aromaterapie, ritualuri simple de zi cu zi. Cine e pe scrisoare află primul când deschid înscrierile.',
    status: 'soon',
  },
  {
    emoji: '💧',
    kicker: 'Discret, doar dacă te interesează',
    title: 'Uleiuri esențiale (Young Living)',
    text: 'Dacă te interesează felul în care folosesc eu uleiurile și vrei să înveți mai mult, putem discuta. Fără liste, fără presiune, fără „echipe”. Doar informație, dacă o cauți.',
    status: 'quiet',
    action: { href: '#contact', label: 'Putem discuta' },
  },
];

const notFor = [
  'Nu promit vindecări și nu înlocuiesc medicul sau farmacistul.',
  'Nu folosesc frica ca să te fac să cumperi ceva.',
  'Nu ofer soluții universale, „bune pentru toată lumea”.',
  'Nu recomand produse înainte să înțeleg omul din fața mea.',
];
---

<BaseLayout
  title="Lucrează cu Alexandra"
  description="Fără presiune, fără promisiuni. Doar claritate. De la scrisorile săptămânale la o discuție om cu om — hai să ne cunoaștem încet."
>
  <!-- ===================== HERO ===================== -->
  <section class="work-hero">
    <div class="container work-hero-inner">
      <div class="work-hero-text">
        <span class="eyebrow">Lucrează cu Alexandra</span>
        <h1 class="work-hero-title">Fără presiune.<br />Doar claritate.</h1>
        <p class="lead work-hero-sub">
          Nu alerg după clienți și nu încerc să-ți vând nimic. Prefer să ne
          cunoaștem încet. Tu citești, eu scriu. Dacă simți că gândim la fel,
          următorul pas vine natural.
        </p>
      </div>
      <div class="work-hero-photo" role="img" aria-label="Un ceai cald, un caiet și câteva plante pe masă"></div>
    </div>
  </section>

  <!-- ===================== START HERE (newsletter) ===================== -->
  <section class="section start-here-section">
    <div class="container">
      <div class="start-here">
        <div class="start-here-body">
          <span class="start-here-kicker">Începe de aici</span>
          <h2 class="start-here-title">
            <span class="start-here-emoji" aria-hidden="true">📨</span>
            Scrisorile săptămânale
          </h2>
          <p class="start-here-text">
            Cel mai bun mod de a mă cunoaște. Îți scriu o dată pe săptămână —
            gânduri, plante și lucruri pe care le învăț. E gratuit și poți
            renunța oricând, dintr-un singur click.
          </p>
        </div>
        <form class="start-here-form" data-newsletter>
          <label class="visually-hidden" for="sh-email">Adresa ta de email</label>
          <input
            id="sh-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="adresa ta de email"
          />
          <button type="submit" class="btn btn-primary">Mă abonez — gratuit</button>
          <p class="start-here-note" data-newsletter-note hidden>
            Gata — te-ai abonat. Ne auzim săptămâna asta. 🌿
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- ===================== OTHER WAYS ===================== -->
  <section class="section surface-cream offers-section">
    <div class="container">
      <div class="offers-head text-center">
        <span class="eyebrow">Și, în timp</span>
        <h2>Alte feluri în care ne putem întâlni</h2>
      </div>
      <div class="offers-list">
        {
          offers.map((o) => (
            <article class:list={['offer', `is-${o.status}`]}>
              <span class="offer-emoji" aria-hidden="true">{o.emoji}</span>
              <div class="offer-body">
                <div class="offer-heading">
                  <span class="offer-kicker">{o.kicker}</span>
                  <h3 class="offer-title">
                    {o.title}
                    {o.status === 'soon' && <span class="offer-badge">În curând</span>}
                  </h3>
                </div>
                <p class="offer-text">{o.text}</p>
                {o.tags && (
                  <ul class="offer-tags">
                    {o.tags.map((t) => (
                      <li>{t}</li>
                    ))}
                  </ul>
                )}
                {o.fineprint && <p class="offer-fineprint">{o.fineprint}</p>}
                {o.action && (
                  <a href={o.action.href} class="offer-link">
                    {o.action.label} →
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== WHAT THIS IS NOT ===================== -->
  <section class="section">
    <div class="container-narrow mx-auto not-for">
      <span class="eyebrow">Ca să fim de la început sinceri</span>
      <h2>Ce nu găsești la mine</h2>
      <ul class="not-for-list">
        {
          notFor.map((item) => (
            <li>
              <span class="not-for-mark" aria-hidden="true">—</span>
              {item}
            </li>
          ))
        }
      </ul>
      <p class="not-for-note">
        Dacă lucrurile astea îți sună a ușurare, nu a lipsă — atunci suntem pe
        aceeași lungime de undă.
      </p>
    </div>
  </section>

  <BotanicalDivider />

  <!-- ===================== CONTACT ===================== -->
  <section id="contact" class="section contact-section">
    <div class="container-narrow mx-auto contact">
      <div class="text-center contact-head">
        <span class="eyebrow">Scrie-mi</span>
        <h2>Ai o întrebare?</h2>
        <p class="lead mx-auto">
          Spune-mi în câteva rânduri despre ce e vorba. Citesc fiecare mesaj și
          răspund cât de repede pot — de obicei în câteva zile.
        </p>
      </div>

      {/*
        TODO (integrare reală): conectează formularul la un serviciu de email
        (ex. Formspree, sau endpoint propriu). Deocamdată afișează un mesaj de
        mulțumire, ca demonstrație.
      */}
      <form class="contact-form" data-contact>
        <div class="field">
          <label for="c-name">Numele tău</label>
          <input id="c-name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="c-email">Adresa de email</label>
          <input id="c-email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="c-message">Mesajul tău</label>
          <textarea id="c-message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-warm">Trimite</button>
      </form>
      <p class="contact-note" data-contact-note hidden>
        Mulțumesc — am primit mesajul tău. Îți răspund cât de curând. 🌿
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===================== HERO ===================== */
  .work-hero {
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
  }

  .work-hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .work-hero-title {
    margin-block: 0.5rem 1.25rem;
    font-size: clamp(2.4rem, 5.5vw, 3.8rem);
    line-height: 1.05;
  }

  .work-hero-sub {
    max-width: 46ch;
    margin-inline: 0;
  }

  .work-hero-photo {
    --photo: url('/images/lucreaza-hero.jpg');
    aspect-ratio: 4 / 5;
    border-radius: var(--radius);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-soft);
    background-image:
      var(--photo),
      radial-gradient(120% 120% at 30% 20%, var(--tint-lavender) 0%, transparent 60%),
      linear-gradient(150deg, #efe7dd, #e8e1d2);
    background-size: cover, auto, auto;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* ===================== START HERE ===================== */
  .start-here {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    background-color: var(--tint-lavender);
    border: 1px solid var(--accent-pink);
    border-radius: var(--radius-lg, 20px);
    padding: clamp(1.75rem, 4vw, 2.75rem);
  }

  .start-here-kicker {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-lavender-deep);
  }

  .start-here-title {
    margin-block: 0.5rem 0.75rem;
    font-size: clamp(1.6rem, 3.5vw, 2.3rem);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .start-here-emoji {
    font-size: 1.5rem;
  }

  .start-here-text {
    color: var(--text-secondary);
    max-width: 52ch;
  }

  .start-here-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .start-here-form input {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.85rem 1.1rem;
    border-radius: var(--radius);
    border: 1.5px solid var(--border-soft);
    background-color: var(--bg-page);
    color: var(--text-main);
    width: 100%;
  }

  .start-here-form input:focus {
    outline: none;
    border-color: var(--accent-lavender);
  }

  .start-here-form .btn {
    width: 100%;
  }

  .start-here-note {
    margin-top: 0.25rem;
    font-weight: 600;
    color: var(--accent-sage-dark);
    text-align: center;
  }

  /* ===================== OFFERS ===================== */
  .offers-head {
    max-width: 620px;
    margin-inline: auto;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .offers-head h2 {
    margin-top: 0.5rem;
  }

  .offers-list {
    display: flex;
    flex-direction: column;
    max-width: 780px;
    margin-inline: auto;
  }

  .offer {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    padding-block: clamp(1.5rem, 3vw, 2.25rem);
    border-top: 1px solid var(--border-soft);
  }

  .offer:first-child {
    border-top: none;
  }

  .offer-emoji {
    font-size: 1.75rem;
    line-height: 1;
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: var(--bg-soft);
    border: 1px solid var(--border-soft);
  }

  .offer-kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-terracotta);
  }

  .offer-title {
    margin-top: 0.3rem;
    font-size: 1.35rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .offer-badge {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    background-color: var(--bg-soft);
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
  }

  .offer-text {
    margin-top: 0.6rem;
    color: var(--text-secondary);
    max-width: none;
  }

  .offer-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.9rem;
  }

  .offer-tags li {
    font-size: 0.8rem;
    color: var(--text-secondary);
    background-color: var(--bg-page);
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    padding: 0.3rem 0.85rem;
  }

  .offer-fineprint {
    margin-top: 0.9rem;
    font-size: 0.85rem;
    font-style: italic;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: none;
  }

  .offer-link {
    display: inline-block;
    margin-top: 1rem;
    font-weight: 600;
    color: var(--accent-sage-dark);
    text-decoration: none;
  }

  .offer-link:hover {
    color: var(--accent-lavender-deep);
  }

  /* ===================== NOT FOR ===================== */
  .not-for h2 {
    margin-block: 0.5rem 1.5rem;
  }

  .not-for-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .not-for-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    font-size: 1.08rem;
    color: var(--ink);
  }

  .not-for-mark {
    color: var(--terracotta);
    font-weight: 700;
    flex: none;
  }

  .not-for-note {
    margin-top: 1.75rem;
    font-style: italic;
    color: var(--ink-soft);
  }

  /* ===================== CONTACT ===================== */
  .contact-head {
    margin-bottom: 2.5rem;
  }

  .contact-head h2 {
    margin-block: 0.5rem 1rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field label {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--ink-soft);
  }

  .field input,
  .field textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.85rem 1.1rem;
    border-radius: var(--radius);
    border: 1.5px solid var(--line);
    background-color: var(--paper);
    color: var(--ink);
    width: 100%;
    resize: vertical;
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--lavender);
  }

  .contact-form .btn {
    align-self: flex-start;
  }

  .contact-note {
    margin-top: 1.25rem;
    font-weight: 700;
    color: var(--sage-deep);
  }

  /* ===================== RESPONSIVE ===================== */
  @media (max-width: 860px) {
    .work-hero-inner {
      grid-template-columns: 1fr;
    }
    .work-hero-photo {
      order: -1;
      aspect-ratio: 16 / 10;
    }
    .start-here {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Demo behaviour until real backends are connected.
  document.querySelectorAll<HTMLFormElement>('form[data-contact]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const note = form.parentElement?.querySelector<HTMLElement>('[data-contact-note]');
      form.hidden = true;
      if (note) note.hidden = false;
    });
  });

  document.querySelectorAll<HTMLFormElement>('form[data-newsletter]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const note = form.querySelector<HTMLElement>('[data-newsletter-note]');
      const input = form.querySelector<HTMLInputElement>('input');
      const button = form.querySelector<HTMLButtonElement>('button');
      if (input) input.hidden = true;
      if (button) button.hidden = true;
      if (note) note.hidden = false;
    });
  });
</script>
