---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import BotanicalDivider from '../components/BotanicalDivider.astro';

// Text-ul paginii vine din Keystatic (editabil în browser). Designul rămâne aici.
const reader = createReader(process.cwd(), keystaticConfig);
const despre = await reader.singletons.despre.read();
if (!despre) {
  throw new Error('Conținutul paginii Despre lipsește (src/content/pages/despre.yaml)');
}

// Nuanțele de fundal rămân în cod (design), rotite pe capitole.
const tints = ['var(--tint-sage)', 'var(--tint-lavender)', 'var(--tint-terracotta)'];
const story = despre.story.map((chapter, i) => ({
  ...chapter,
  tint: tints[i % tints.length],
  // Textul e un singur câmp; paragrafele se despart prin rânduri goale.
  paragraphs: chapter.body
    .split(/\n{2,}/)
    .map((p) => p.trim())
    .filter(Boolean),
}));

const beliefs = despre.beliefs;
---

<BaseLayout
  title="Despre Alexandra"
  description="Povestea Alexandrei — cum a început, de ce iubește plantele, cum a descoperit aromaterapia și felul holistic în care privește omul și natura."
>
  <!-- ===================== HERO ===================== -->
  <section class="section about-hero">
    <div class="container about-hero-grid">
      <div class="about-hero-text">
        <span class="eyebrow">{despre.heroEyebrow}</span>
        <h1>{despre.heroTitle}</h1>
        <p class="lead">{despre.heroLead}</p>
        <p>{despre.heroBody}</p>
      </div>

      <div
        class="about-portrait"
        role="img"
        aria-label="Portret cald cu Alexandra"
      ></div>
    </div>
  </section>

  <!-- ===================== STORY ===================== -->
  <section class="section story">
    <div class="container">
      {
        story.map((chapter, i) => (
          <article class:list={['chapter', { alt: i % 2 === 1 }]}>
            <div
              class="chapter-photo"
              role="img"
              aria-label={chapter.alt}
              style={`--photo:url('${chapter.photo ?? ''}'); --tint:${chapter.tint}`}
            />
            <div class="chapter-text">
              <span class="chapter-kicker">{chapter.kicker}</span>
              <h2 class="chapter-title">{chapter.title}</h2>
              {chapter.paragraphs.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ===================== PRINCIPLES ===================== -->
  <section class="section surface-cream beliefs">
    <div class="container">
      <div class="beliefs-head text-center">
        <span class="eyebrow">{despre.beliefsEyebrow}</span>
        <h2>{despre.beliefsTitle}</h2>
      </div>
      <div class="beliefs-grid">
        {
          beliefs.map((b, i) => (
            <div class="belief">
              <span class="belief-num">{String(i + 1).padStart(2, '0')}</span>
              <h3>{b.title}</h3>
              <p>{b.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <BotanicalDivider />

  <section class="section">
    <div class="container">
      <NewsletterSignup
        eyebrow="Rămâi aproape"
        title="Hai să ținem legătura"
        text="Din când în când îți scriu personal — un gând, un mic ritual, lucruri pe care le învăț. Simplu, cald, fără spam."
      />
    </div>
  </section>
</BaseLayout>

<style>
  /* ===================== HERO ===================== */
  .about-hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .about-hero h1 {
    margin-block: 0.5rem 1.25rem;
  }

  .about-hero em {
    font-style: italic;
    color: var(--lavender-deep);
  }

  .about-portrait {
    --photo: url('/images/despre-portret.jpg');
    width: min(100%, 340px);
    justify-self: center;
    aspect-ratio: 4 / 5;
    border-radius: 180px 180px var(--radius-lg) var(--radius-lg);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-soft);
    transform: rotate(1.5deg);
    background-image:
      var(--photo),
      linear-gradient(160deg, var(--tint-sage), var(--tint-lavender));
    background-size: cover, auto;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* ===================== STORY ===================== */
  .story {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 7vw, 5.5rem);
  }

  .chapter {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(1.75rem, 5vw, 3.5rem);
  }

  .chapter.alt .chapter-photo {
    order: 2;
  }

  .chapter-photo {
    aspect-ratio: 5 / 4;
    border-radius: var(--radius);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-card);
    background-image:
      var(--photo),
      radial-gradient(120% 120% at 30% 25%, var(--tint) 0%, transparent 60%),
      linear-gradient(150deg, #efe7dd, #e8e1d2);
    background-size: cover, auto, auto;
    background-position: center;
    background-repeat: no-repeat;
  }

  .chapter-kicker {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-terracotta);
  }

  .chapter-title {
    margin-block: 0.5rem 1rem;
    font-size: clamp(1.6rem, 3.4vw, 2.3rem);
  }

  .chapter-text p {
    color: var(--text-secondary);
  }

  .chapter-text p + p {
    margin-top: 1rem;
  }

  /* ===================== PRINCIPLES ===================== */
  .beliefs-head {
    max-width: 620px;
    margin-inline: auto;
    margin-bottom: 3rem;
  }

  .beliefs-head h2 {
    margin-top: 0.5rem;
  }

  .beliefs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }

  .belief {
    background-color: var(--paper);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    box-shadow: var(--shadow-card);
  }

  .belief-num {
    font-family: var(--font-display);
    font-size: 2.2rem;
    color: var(--lavender-soft);
    display: block;
    margin-bottom: 0.5rem;
  }

  .belief h3 {
    font-size: 1.3rem;
    margin-bottom: 0.6rem;
  }

  .belief p {
    color: var(--ink-soft);
    font-size: 0.98rem;
    max-width: none;
  }

  /* ===================== RESPONSIVE ===================== */
  @media (max-width: 860px) {
    .about-hero-grid {
      grid-template-columns: 1fr;
    }
    .about-portrait {
      order: -1;
      width: min(72%, 300px);
    }
    .chapter {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .chapter.alt .chapter-photo {
      order: -1;
    }
    .chapter-photo {
      order: -1;
    }
    .beliefs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
