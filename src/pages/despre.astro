---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import BotanicalDivider from '../components/BotanicalDivider.astro';

// Her story, told in scenes rather than as a résumé. Each chapter pairs a few
// warm paragraphs with a real photo slot (graceful fallback until the image
// lands under /public/images/despre/).
const story = [
  {
    kicker: 'Începutul',
    title: 'Nu am pornit dintr-un plan',
    photo: '/images/despre/inceput.jpg',
    alt: 'Alexandra printre plante, la început de drum',
    tint: 'var(--tint-sage)',
    paragraphs: [
      'Am pornit dintr-o curiozitate care nu m-a mai lăsat. La început au fost întrebări mărunte — de ce mă liniștește un ceai, de ce miroase altfel lavanda uscată la soare, de ce unele lucruri simple ajută mai mult decât cele complicate.',
      'Nu căutam o afacere. Căutam să înțeleg. Iar cu cât înțelegeam mai mult, cu atât îmi doream să împărtășesc — calm, fără să vând nimic.',
    ],
  },
  {
    kicker: 'De ce iubesc plantele',
    title: 'Plantele nu se grăbesc',
    photo: '/images/despre/plante.jpg',
    alt: 'Plante medicinale și mâinile Alexandrei',
    tint: 'var(--tint-lavender)',
    paragraphs: [
      'Îmi plac plantele pentru că ne învață răbdare. Nu promit rezultate peste noapte și nu funcționează prin forță. Cresc în ritmul lor și ne cheamă să încetinim și noi.',
      'Le studiez, le cultiv, le usuc, le încerc. Vreau să știu ce recomand — nu din prima pagină de Google, ci din experiență trăită.',
    ],
  },
  {
    kicker: 'Aromaterapia',
    title: 'Am descoperit uleiurile aproape din întâmplare',
    photo: '/images/despre/aromaterapie.jpg',
    alt: 'Sticluțe de uleiuri esențiale și flori de lavandă',
    tint: 'var(--tint-terracotta)',
    paragraphs: [
      'Aromaterapia a intrat în viața mea discret și a rămas. M-a fascinat cât de mult poate schimba o zi un miros potrivit, la momentul potrivit — un pic de calm seara, un pic de limpezime dimineața.',
      'De atunci citesc, testez și învăț continuu. Le privesc ca pe un sprijin blând, niciodată ca pe o soluție-minune.',
    ],
  },
  {
    kicker: 'Învăț continuu',
    title: 'De ce merg la conferințe',
    photo: '/images/despre/conferinte.jpg',
    alt: 'Alexandra la o conferință, luând notițe',
    tint: 'var(--tint-sage)',
    paragraphs: [
      'Merg la conferințe și la producători pentru că vreau să înțeleg, nu doar să repet. Vreau să văd cu ochii mei, să întreb, să verific. Vizitez ferme și distilerii, ascult oameni care fac asta de-o viață.',
      'Tot ce ajunge aici trece întâi prin filtrul acesta: are sens? l-am înțeles cu adevărat? l-aș folosi eu?',
    ],
  },
];

// Positive principles — what stays constant, told as a promise, not a CV.
const beliefs = [
  {
    title: 'Omul întreg, nu simptomul',
    text: 'Nu mă grăbesc să dau o soluție. Întâi întreb: cum dormi, cât ești sub stres, ce mănânci, cum arată o zi obișnuită? De acolo pornim.',
  },
  {
    title: 'Fără promisiuni, fără frică',
    text: 'Nu vând vindecări și nu sperii pe nimeni. Împărtășesc ce am învățat, cu nuanțe și cu onestitate — inclusiv ce nu funcționează.',
  },
  {
    title: 'Experiență, nu copy-paste',
    text: 'Ce scriu vine din cărți, conferințe, vizite la producători și din propriile experimente — trăit, nu copiat.',
  },
];
---

<BaseLayout
  title="Despre Alexandra"
  description="Povestea Alexandrei — cum a început, de ce iubește plantele, cum a descoperit aromaterapia și felul holistic în care privește omul și natura."
>
  <!-- ===================== HERO ===================== -->
  <section class="section about-hero">
    <div class="container about-hero-grid">
      <div class="about-hero-text">
        <span class="eyebrow">Despre Alexandra</span>
        <h1>Bună, sunt Alexandra.</h1>
        <p class="lead">
          De ani buni citesc, studiez și experimentez tot ce ține de plante,
          aromaterapie și o viață mai naturală. Nu ca să vând ceva — ci pentru
          că mă fascinează și pentru că îmi place să împărtășesc.
        </p>
        <p>
          Oamenii îmi scriu des și îmi spun că le place <em>felul în care
          gândesc</em>. Cred că se întâmplă pentru că nu ofer răspunsuri de-a
          gata. Încerc să înțeleg întâi omul din fața mea, cu tot ce ține de el,
          și abia apoi vorbim despre plante și uleiuri — ca parte dintr-un
          întreg, niciodată ca soluție-minune.
        </p>
      </div>

      <div
        class="about-portrait"
        role="img"
        aria-label="Portret cald cu Alexandra"
      ></div>
    </div>
  </section>

  <!-- ===================== STORY ===================== -->
  <section class="section story">
    <div class="container">
      {
        story.map((chapter, i) => (
          <article class:list={['chapter', { alt: i % 2 === 1 }]}>
            <div
              class="chapter-photo"
              role="img"
              aria-label={chapter.alt}
              style={`--photo:url('${chapter.photo}'); --tint:${chapter.tint}`}
            />
            <div class="chapter-text">
              <span class="chapter-kicker">{chapter.kicker}</span>
              <h2 class="chapter-title">{chapter.title}</h2>
              {chapter.paragraphs.map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ===================== PRINCIPLES ===================== -->
  <section class="section surface-cream beliefs">
    <div class="container">
      <div class="beliefs-head text-center">
        <span class="eyebrow">În ce cred</span>
        <h2>Trei lucruri care nu se schimbă</h2>
      </div>
      <div class="beliefs-grid">
        {
          beliefs.map((b, i) => (
            <div class="belief">
              <span class="belief-num">{String(i + 1).padStart(2, '0')}</span>
              <h3>{b.title}</h3>
              <p>{b.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <BotanicalDivider />

  <section class="section">
    <div class="container">
      <NewsletterSignup
        eyebrow="Rămâi aproape"
        title="Hai să ținem legătura"
        text="Îți scriu o dată pe săptămână — gânduri, plante și lucruri pe care le învăț. Simplu, cald, fără spam."
      />
    </div>
  </section>
</BaseLayout>

<style>
  /* ===================== HERO ===================== */
  .about-hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .about-hero h1 {
    margin-block: 0.5rem 1.25rem;
  }

  .about-hero em {
    font-style: italic;
    color: var(--lavender-deep);
  }

  .about-portrait {
    --photo: url('/images/despre-portret.jpg');
    width: min(100%, 340px);
    justify-self: center;
    aspect-ratio: 4 / 5;
    border-radius: 180px 180px var(--radius-lg) var(--radius-lg);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-soft);
    transform: rotate(1.5deg);
    background-image:
      var(--photo),
      linear-gradient(160deg, var(--tint-sage), var(--tint-lavender));
    background-size: cover, auto;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* ===================== STORY ===================== */
  .story {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 7vw, 5.5rem);
  }

  .chapter {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(1.75rem, 5vw, 3.5rem);
  }

  .chapter.alt .chapter-photo {
    order: 2;
  }

  .chapter-photo {
    aspect-ratio: 5 / 4;
    border-radius: var(--radius);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-card);
    background-image:
      var(--photo),
      radial-gradient(120% 120% at 30% 25%, var(--tint) 0%, transparent 60%),
      linear-gradient(150deg, #efe7dd, #e8e1d2);
    background-size: cover, auto, auto;
    background-position: center;
    background-repeat: no-repeat;
  }

  .chapter-kicker {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-terracotta);
  }

  .chapter-title {
    margin-block: 0.5rem 1rem;
    font-size: clamp(1.6rem, 3.4vw, 2.3rem);
  }

  .chapter-text p {
    color: var(--text-secondary);
  }

  .chapter-text p + p {
    margin-top: 1rem;
  }

  /* ===================== PRINCIPLES ===================== */
  .beliefs-head {
    max-width: 620px;
    margin-inline: auto;
    margin-bottom: 3rem;
  }

  .beliefs-head h2 {
    margin-top: 0.5rem;
  }

  .beliefs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }

  .belief {
    background-color: var(--paper);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    box-shadow: var(--shadow-card);
  }

  .belief-num {
    font-family: var(--font-display);
    font-size: 2.2rem;
    color: var(--lavender-soft);
    display: block;
    margin-bottom: 0.5rem;
  }

  .belief h3 {
    font-size: 1.3rem;
    margin-bottom: 0.6rem;
  }

  .belief p {
    color: var(--ink-soft);
    font-size: 0.98rem;
    max-width: none;
  }

  /* ===================== RESPONSIVE ===================== */
  @media (max-width: 860px) {
    .about-hero-grid {
      grid-template-columns: 1fr;
    }
    .about-portrait {
      order: -1;
      width: min(72%, 300px);
    }
    .chapter {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .chapter.alt .chapter-photo {
      order: -1;
    }
    .chapter-photo {
      order: -1;
    }
    .beliefs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
